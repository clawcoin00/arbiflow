# ArbiFlow environment
# Generated by `npm run env:example`.
# Local development should mirror Vercel production via `npm run env:sync`.
# Add deliberate local-only differences in `.env.local.override`.

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Optional fallback for older projects still using anon keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# App URLs
# Optional canonical URL override. Route handlers derive the current origin automatically.
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# Notifications
TELEGRAM_BOT_TOKEN=
# For private groups, prefer numeric chat ids such as -1001234567890.
TELEGRAM_CHAT_ID=

# Alert Thresholds
ALERT_EDGE_MIN=0.05
ALERT_COOLDOWN_MS=1800000

# Data Sources
POLYMARKET_API_BASE=
OPINION_API_BASE=
OPINION_API_KEY=
KALSHI_API_BASE=
PROBO_API_BASE=
PREDICTFUN_API_BASE=
PREDICTFUN_API_KEY=
LIMITLESS_API_BASE=
LIMITLESS_API_KEY=

# Persistence
DATABASE_URL="file:./dev.db"

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO_WEEKLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_WEBHOOK_SECRET=

# Twitter/X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
